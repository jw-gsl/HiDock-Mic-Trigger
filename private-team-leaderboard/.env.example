# Copy to the private ai-token-monitor fork root as `.env` or `.env.production`
# (Vite loads these at build / `tauri dev` time).

# Project Settings → API → Project URL
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Project Settings → API → anon public key (safe in the desktop client; RLS + allowlist protect data)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Never put the service_role key in the app.
